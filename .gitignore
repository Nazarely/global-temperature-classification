# =============================================================================
# .gitignore — Clasificación de Temperaturas Globales
# =============================================================================

# ----- Datos -----
# No subir datasets pesados ni datos sensibles
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.zip
*.csv

# Mantener la estructura de carpetas aunque estén vacías
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep
!outputs/figures/.gitkeep

# ----- R específico -----
# Historial y entorno de sesión
.Rhistory
.Rapp.history
.RData
.Ruserdata
.Rproj.user/

# Archivos de proyecto RStudio
*.Rproj

# Cache de paquetes
packrat/lib*/
packrat/src/

# renv (manejo de entornos)
renv/library/
renv/staging/

# ----- Outputs generados -----
# Los gráficos se regeneran al correr el script
outputs/figures/*.png
outputs/figures/*.pdf
outputs/figures/*.svg

# ----- Sistema operativo -----
# macOS
.DS_Store
.AppleDouble
.LSOverrideIcon

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ----- IDEs y editores -----
.vscode/
.idea/
*.swp
*.swo
